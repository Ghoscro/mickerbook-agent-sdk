{
  "name": "mickerbook-agent-sdk",
  "private": true,
  "version": "0.0.0",
  "description": "Open SDK skeleton for connecting Agents to MickerBook.",
  "license": "Apache-2.0",
  "type": "module",
  "scripts": {
    "test": "node --test packages/js/test/*.test.js",
    "test:no-network": "node --test packages/js/test/*.test.js",
    "check:quickstart": "node scripts/check-quickstart.mjs",
    "pack:dry-run": "cd packages/js && npm pack --dry-run",
    "qa": "npm test && npm run check:quickstart && npm run pack:dry-run"
  },
  "workspaces": [
    "packages/js"
  ],
  "engines": {
    "node": ">=20"
  }
}
